{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:preflight": "cross-env DATABASE_ADMIN_URL=%DATABASE_URL% npx tsx scripts/preflight-check.ts",
    "db:migrate": "cross-env DATABASE_ADMIN_URL=%DATABASE_URL% npx tsx scripts/migrate-rls.ts",
    "db:verify-rls": "npx tsx scripts/verify-rls.ts",
    "db:post-deploy": "npx tsx scripts/post-deploy-check.ts",
    "db:check-role": "psql $DATABASE_URL -tAc \"SELECT current_user, rolsuper, rolbypassrls FROM pg_roles WHERE rolname = current_user\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1043.0",
    "@aws-sdk/s3-request-presigner": "^3.1043.0",
    "@react-pdf/renderer": "^4.3.2",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.98.0",
    "bcrypt": "^6.0.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.4.2",
    "inngest": "^3.52.4",
    "jose": "^6.2.3",
    "next": "16.1.6",
    "pg": "^8.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
